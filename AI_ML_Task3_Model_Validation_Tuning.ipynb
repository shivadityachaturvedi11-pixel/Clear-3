# # Task-3: Model Validation and Hyperparameter Tuning
# **Dataset:** California Housing Dataset
import numpy as np
import pandas as pd
import matplotlib.pyplot as plt

from sklearn.datasets import fetch_california_housing
from sklearn.model_selection import train_test_split, cross_val_score, GridSearchCV
from sklearn.preprocessing import StandardScaler
from sklearn.linear_model import LinearRegression, Ridge
from sklearn.tree import DecisionTreeRegressor
from sklearn.metrics import mean_squared_error, r2_score

# ==========================================
# Step 2: Load and Prepare Dataset
# ==========================================
print("--- Loading California Housing Dataset ---")
data = fetch_california_housing(as_frame=True)
df = pd.concat([data.data, data.target.rename("HousePrice")], axis=1)

# Separate features and target
X = df.drop("HousePrice", axis=1)
y = df["HousePrice"]

# ==========================================
# Step 3: Feature Scaling (Same as Task-2)
# ==========================================
scaler = StandardScaler()
X_scaled = scaler.fit_transform(X)

# ==========================================
# Step 4: Train-Test Split
# ==========================================
X_train, X_test, y_train, y_test = train_test_split(
    X_scaled, y, test_size=0.2, random_state=42
)

# ==========================================
# Step 5: Detect Overfitting (Train vs Test Performance)
# ==========================================
print("\n--- Step 5: Detecting Overfitting on Base Decision Tree ---")
tree = DecisionTreeRegressor(random_state=42)
tree.fit(X_train, y_train)

train_pred = tree.predict(X_train)
test_pred = tree.predict(X_test)

# In newer scikit-learn versions, use root_mean_squared_error or set squared=False
train_rmse = mean_squared_error(y_train, train_pred, squared=False)
test_rmse = mean_squared_error(y_test, test_pred, squared=False)

print(f"Base Tree - Train RMSE: {train_rmse:.4f}")
print(f"Base Tree - Test RMSE: {test_rmse:.4f}")
print("Interpretation: A massive gap here shows that an unconstrained tree overfits heavily.")

# ==========================================
# Step 6: Cross-Validation (Reliable Evaluation)
# ==========================================
print("\n--- Step 6: Running Cross-Validation on Base Tree ---")
cv_scores = cross_val_score(
    tree, X_scaled, y, scoring="neg_root_mean_squared_error", cv=5
)
cv_rmse = -cv_scores.mean()
print(f"5-Fold Cross-Validated Base Tree RMSE: {cv_rmse:.4f}")

# ==========================================
# Step 7: Hyperparameter Tuning Using GridSearchCV
# ==========================================
print("\n--- Step 7: Starting Hyperparameter Tuning (GridSearchCV) ---")
param_grid = {
    'max_depth': [3, 5, 7, 10],
    'min_samples_split': [2, 5, 10]
}

grid = GridSearchCV(
    DecisionTreeRegressor(random_state=42),
    param_grid,
    scoring="neg_root_mean_squared_error",
    cv=5,
    n_jobs=-1 # Uses all processor cores for faster execution
)
grid.fit(X_train, y_train)

print(f"Best Parameters Found: {grid.best_params_}")

# ==========================================
# Step 8: Evaluate Optimized Model
# ==========================================
print("\n--- Step 8: Evaluating the Tuned Model on Test Data ---")
best_tree = grid.best_estimator_
y_pred = best_tree.predict(X_test)

tuned_rmse = mean_squared_error(y_test, y_pred, squared=False)
tuned_r2 = r2_score(y_test, y_pred)

print(f"Tuned Tree - Test RMSE: {tuned_rmse:.4f}")
print(f"Tuned Tree - Test R2 Score: {tuned_r2:.4f}")

# ==========================================
# Step 9: Model Comparison Summary Table
# ==========================================
print("\n--- Step 9: Compiling Model Comparison Table ---")

# Mock values for Task-2 Baselines (Replace these with your exact Task-2 values if available)
lr_rmse, lr_r2 = 0.7455, 0.5758
ridge_rmse, ridge_r2 = 0.7455, 0.5758

results = {
    "Model": ["Linear Regression", "Ridge Regression", "Tuned Decision Tree"],
    "RMSE": [lr_rmse, ridge_rmse, tuned_rmse],
    "R2 Score": [lr_r2, ridge_r2, tuned_r2]
}

df_results = pd.DataFrame(results)
print("\nFinal Performance Summary:")
print(df_results.to_string(index=False))

# Optional Step: Visualizing the performance difference
df_results.set_index("Model")["RMSE"].plot(kind="bar", color=["skyblue", "orange", "green"])
plt.title("Model Comparison - RMSE (Lower is Better)")
plt.ylabel("RMSE")
plt.xticks(rotation=15)
plt.tight_layout()
plt.show()
